# =============================================================================
# Django 核心配置（安全敏感，生产环境必须修改）
# =============================================================================

# Django 密钥 - 用于加密会话、CSRF 令牌等
# 生产环境必须使用强随机字符串，建议使用以下命令生成：
# python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-this-in-production-to-a-strong-secret-key

# Django 调试模式
# 生产环境必须设置为 False！
DJANGO_DEBUG=True

# 允许的主机名
# 生产环境设置为实际域名，多个域名用逗号分隔
# 例如: DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_ALLOWED_HOSTS=*

# =============================================================================
# Django 超级用户配置（首次启动时创建）
# =============================================================================

# 超级用户用户名
DJANGO_SUPERUSER_USERNAME=admin

# 超级用户密码
# 生产环境必须修改为强密码！
# 建议使用至少 12 位包含大小写字母、数字和特殊字符的密码
DJANGO_SUPERUSER_PASSWORD=change-this-to-a-strong-password

# 超级用户邮箱
DJANGO_SUPERUSER_EMAIL=admin@example.com

# =============================================================================
# Django 运行配置
# =============================================================================

# Django 设置模块
DJANGO_SETTINGS_MODULE=warehouse.settings

# Python 输出缓冲（Docker 中建议开启）
PYTHONUNBUFFERED=1

# =============================================================================
# 使用说明
# =============================================================================
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改 .env 中的敏感配置（特别是 DJANGO_SECRET_KEY 和 DJANGO_SUPERUSER_PASSWORD）
# 3. docker-compose.yml 会自动读取 .env 文件
# 4. 生产环境请确保：
#    - DJANGO_DEBUG=False
#    - DJANGO_SECRET_KEY 使用强随机字符串
#    - DJANGO_SUPERUSER_PASSWORD 使用强密码
#    - DJANGO_ALLOWED_HOSTS 设置为实际域名
